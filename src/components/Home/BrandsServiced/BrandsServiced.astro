---
import Image from "astro/components/Image.astro";
import brands from "../../../assets/brands.png";
import { getImage } from "astro:assets";

const img = await getImage({
	src: brands,
	width: 700,
	height: 400,
	format: "webp",
	quality: 80,
});
---

<Fragment slot="head">
	<link rel="preload" href={img.src} as="image" />
</Fragment>

<section class="brands-section">
	<div class="brands-inner">
		<div class="brands-text">
			<p class="eyebrow">No Brand Left Behind</p>
			<h2 class="title">We service all brands</h2>
			<p class="subtitle">
				From Rain Bird and Hunter to Toro and Irritrol. If it irrigates, we fix it.
			</p>
		</div>
		<div class="brands-img-container">
			<Image
				src={img.src}
				alt="Irrigation brands serviced: Rain Bird, Hunter, Toro, Irritrol, Nelson, WM"
				width={img.attributes.width}
				height={img.attributes.height}
			/>
		</div>
	</div>
</section>

<style>
	.brands-section {
		background: var(--color-lighter-neutral);
		width: 100%;
		padding: 6rem 4rem;
		border-top: 1px solid rgba(0, 0, 0, 0.06);

		@media (max-width: 768px) {
			padding: 4rem 1.5rem;
		}
	}

	.brands-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 5rem;

		@media (max-width: 900px) {
			flex-direction: column;
			gap: 2.5rem;
			text-align: center;
		}
	}

	.brands-text {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 1rem;

		.eyebrow {
			font-size: 0.8rem;
			font-weight: 700;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--color-primary);
		}

		.title {
			font-size: clamp(2rem, 4vw, 2.75rem);
			font-weight: 800;
			color: var(--color-secondary);
			line-height: 1.15;
		}

		.subtitle {
			font-size: 1.05rem;
			line-height: 1.65;
			color: #555;
			max-width: 380px;

			@media (max-width: 900px) {
				max-width: 100%;
			}
		}
	}

	.brands-img-container {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;

		img {
			width: 100%;
			max-width: 560px;
			height: auto;
			object-fit: contain;
		}
	}
</style>
