---
import { MAIN_PHONE_NUMBER } from "../../../constants/contact-constants";
---

<div class="splash-wrapper">
  <div class="splash-img"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">
      <i class="ti ti-map-pin"></i> Serving North Fort Worth &amp; DFW
    </p>
    <h1>
      Sprinkler Repair<br /><span class="hero-accent">Done Right.</span>
    </h1>
    <p class="hero-sub">
      25 years of irrigation repair across North Fort Worth and DFW. Leaks,
      valves, tune-ups and wiring.
    </p>
    <div class="hero-actions">
      <a href={`tel:${MAIN_PHONE_NUMBER}`} class="hero-cta">
        <i class="ti ti-phone"></i> Call {MAIN_PHONE_NUMBER}
      </a>
      <a href="/services" class="hero-cta-secondary">See Our Services</a>
    </div>
  </div>
</div>

<style>
  .splash-wrapper {
    position: relative;
    width: 100vw;
    min-width: 100vw;
    max-width: 100vw;
  }

  .splash-img {
    width: 100%;
    background-image: url("../../../assets/sprinkler-2.webp");
    background-size: cover;
    background-position: center 20%;
    height: 620px;

    @media (min-width: 1440px) {
      height: 720px;
    }

    @media (max-width: 1100px) {
      height: 520px;
      background-position: 20% 35%;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(33, 37, 64, 0.92) 0%,
      rgba(33, 37, 64, 0.7) 45%,
      rgba(33, 37, 64, 0.2) 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 4rem 6rem;
    gap: 1.5rem;
    max-width: 800px;

    @media (max-width: 900px) {
      padding: 3rem 2.5rem;
      gap: 1.25rem;
    }

    @media (max-width: 480px) {
      padding: 2rem 1.5rem;
    }
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);

    i {
      font-size: 1rem;
    }
  }

  h1 {
    color: #fff;
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
  }

  .hero-accent {
    color: var(--color-primary);
  }

  .hero-sub {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    max-width: 480px;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background-color: var(--color-primary);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(152, 164, 90, 0.45);
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;

    &:hover {
      background-color: var(--color-primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(152, 164, 90, 0.55);
    }

    @media (max-width: 480px) {
      font-size: 0.95rem;
      padding: 0.85rem 1.5rem;
    }
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 1rem 1.75rem;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(4px);
    transition:
      background 0.2s ease,
      transform 0.2s ease;

    &:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateY(-2px);
    }

    @media (max-width: 480px) {
      font-size: 0.95rem;
      padding: 0.85rem 1.5rem;
    }
  }
</style>
