---
import { getImage } from "astro:assets";
import Image from "astro/components/Image.astro";
import randy from "../assets/randy_headshot.jpg";
import Layout from "../layouts/Layout.astro";

const img = await getImage({
	src: randy,
	width: 320,
	height: 380,
	format: "webp",
	quality: 80,
});
---

<Layout
  noPadding
  title="About Randy Hair & A-1 Sprinkler Repair"
  description="Meet Randy Hair, founder of A-1 Sprinkler Repair with over 25 years of expertise in irrigation system repair and maintenance in the DFW area."
  keywords="Randy Hair, A-1 Sprinkler Repair owner, irrigation expert Dallas, sprinkler repair experience, DFW irrigation specialist"
>
  <div class="about-hero">
    <p class="about-eyebrow">The Man Behind the Work</p>
    <h1>About Randy Hair</h1>
    <p class="about-hero-sub">
      Owner and licensed irrigator serving DFW for over 25 years.
    </p>
  </div>

  <div class="container">
    <div class="about-content">
      <div class="about-image">
        <Image
          src={img.src}
          width={img.attributes.width}
          height={img.attributes.height}
          alt="Randy Hair"
          style="object-fit: cover;"
        />
        <Fragment slot="head">
          <link rel="preload" href={img.src} as="image" />
        </Fragment>
        <p class="photo-caption">Randy Hair, Owner &amp; Licensed Irrigator</p>
      </div>
      <div class="about-bio">
        <p>
          For over 25 years, Randy Hair and A-1 Sprinkler Repair have been
          providing irrigation services to homeowners across the DFW area. Randy
          specializes in all aspects of irrigation system repair and takes real
          satisfaction in diagnosing the problems others miss. His focus is on
          getting it done right and making sure it holds up.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .about-hero {
    background: var(--color-secondary);
    color: #fff;
    text-align: center;
    padding: 5rem 2rem 4.5rem;

    .about-eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }

    h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.05;
      margin-bottom: 1rem;
    }

    .about-hero-sub {
      font-size: 1.15rem;
      opacity: 0.75;
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .about-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    width: 100%;
  }

  .about-image {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;

    img {
      border-radius: 1.5rem;
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.13);
      width: 320px;
      height: 380px;
      object-fit: cover;
      background: #f6f6f6;
    }

    .photo-caption {
      font-size: 0.9rem;
      color: var(--color-secondary);
      opacity: 0.7;
      text-align: center;
      font-style: italic;
    }
  }

  .about-bio {
    flex: 1 1 0%;

    p {
      font-size: 1.25rem;
      line-height: 1.75;
      color: var(--color-text);
      margin: 0;
      text-align: left;
      max-width: 540px;
    }
  }

  @media (max-width: 900px) {
    .container {
      padding: 3rem 1.5rem;
    }

    .about-content {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .about-image {
      flex: none;

      img {
        width: 220px;
        height: 260px;
      }
    }

    .about-bio p {
      text-align: left;
      max-width: 100%;
    }
  }

  @media (min-width: 1200px) {
    .about-image {
      flex: 0 0 400px;

      img {
        width: 400px;
        height: 480px;
      }
    }
  }
</style>
