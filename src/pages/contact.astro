---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button/Button.astro";
import { MAIN_PHONE_NUMBER } from "../constants/contact-constants";
import sprinkler1 from "../assets/sprinkler-1.png";
import sprinkler3 from "../assets/sprinkler-3.jpg";
import Image from "astro/components/Image.astro";
import { getImage } from "astro:assets";

const img1 = await getImage({
	src: sprinkler1,
	width: 420,
	height: 288,
	format: "webp",
	quality: 80,
});
const img3 = await getImage({
	src: sprinkler3,
	width: 420,
	height: 288,
	format: "webp",
	quality: 80,
});
---

<Layout
  noPadding
  title="Contact A-1 Sprinkler Repair"
  description="Ready to schedule sprinkler repair? Contact A-1 Sprinkler Repair for professional irrigation services in the DFW area. Call today for fast, reliable service."
  keywords="contact sprinkler repair, schedule irrigation service, DFW sprinkler repair contact, A-1 Sprinkler Repair phone number"
>
  <div class="contact-hero">
    <p class="contact-eyebrow">Get in Touch</p>
    <h1>Contact Us</h1>
    <p class="contact-hero-sub">Serving North Fort Worth and DFW. Give us a call and we'll get it sorted.</p>
  </div>

  <div class="contact-container">
    <div class="contact-content">
      <p>Have a question or need to schedule a repair? We're ready to help.</p>
      <Button
        color="primary"
        size="xlarge"
        onclick={`window.location.href='tel:${MAIN_PHONE_NUMBER}';`}
      >
        Call {MAIN_PHONE_NUMBER}
      </Button>
    </div>
    <div class="contact-images">
      <Image
        src={img1.src}
        alt="Sprinkler repair in action"
        width={img1.attributes.width}
        height={img1.attributes.height}
        class="contact-img"
      />
      <Fragment slot="head">
        <link rel="preload" href={img1.src} as="image" />
      </Fragment>
      <Image
        src={img3.src}
        alt="Healthy green lawn"
        width={img3.attributes.width}
        height={img3.attributes.height}
        class="contact-img"
      />
      <Fragment slot="head">
        <link rel="preload" href={img3.src} as="image" />
      </Fragment>
    </div>
  </div>
</Layout>

<style>
  .contact-hero {
    background: var(--color-secondary);
    color: #fff;
    text-align: center;
    padding: 5rem 2rem 4.5rem;

    .contact-eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }

    h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.05;
      margin-bottom: 1rem;
    }

    .contact-hero-sub {
      font-size: 1.15rem;
      opacity: 0.75;
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }
  }

  .contact-container {
    width: 100vw;
    max-width: 100vw;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 4vw;
    padding: 5rem 4vw;
    background: var(--color-lighter-neutral);
    box-sizing: border-box;
  }

  .contact-content {
    flex: 1 1 0%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
    max-width: 400px;
    min-width: 260px;

    p {
      font-size: 1.2rem;
      color: var(--color-secondary);
      line-height: 1.65;
      margin: 0;
    }
  }

  .contact-images {
    flex: 1 1 0%;
    display: flex;
    flex-direction: row;
    gap: 1.25rem;
    align-items: center;
    justify-content: center;
    min-width: 220px;
    max-width: 560px;
    width: 100%;
  }

  .contact-img {
    width: 100%;
    flex: 1 1 0%;
    height: 300px;
    max-height: 300px;
    border-radius: 1.2rem;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.11);
    object-fit: cover;
    background: #f6f6f6;
    transition: transform 0.2s;
    display: block;
  }

  .contact-img:hover {
    transform: scale(1.025);
  }

  @media (max-width: 1100px) {
    .contact-container {
      flex-direction: column;
      gap: 3rem;
      padding: 4rem 2rem;
    }

    .contact-content {
      align-items: center;
      text-align: center;
      max-width: 100%;
      min-width: 0;
    }

    .contact-images {
      max-width: 100%;
      min-width: 0;
    }

    .contact-img {
      height: 220px;
      max-height: 220px;
      border-radius: 0.8rem;
    }
  }

  @media (max-width: 600px) {
    .contact-container {
      padding: 3rem 1.25rem;
      gap: 2rem;
    }

    .contact-images {
      flex-direction: column;
      gap: 1rem;
    }

    .contact-img {
      height: 200px;
      max-height: 200px;
      border-radius: 0.75rem;
      width: 100%;
    }
  }
</style>
