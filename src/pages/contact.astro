---
import { getImage } from "astro:assets";
import sprinkler3 from "../assets/sprinkler-3.jpg";
import { MAIN_PHONE_NUMBER } from "../constants/contact-constants";
import Layout from "../layouts/Layout.astro";

const bgImg = await getImage({
	src: sprinkler3,
	width: 1600,
	height: 500,
	format: "webp",
	quality: 80,
});
---

<Layout
  noPadding
  title="Contact A-1 Sprinkler Repair"
  description="Ready to schedule sprinkler repair? Contact A-1 Sprinkler Repair for professional irrigation services in the DFW area. Call today for fast, reliable service."
  keywords="contact sprinkler repair, schedule irrigation service, DFW sprinkler repair contact, A-1 Sprinkler Repair phone number"
>
  <Fragment slot="head">
    <link rel="preload" href={bgImg.src} as="image" />
  </Fragment>

  <div class="contact-hero">
    <p class="contact-eyebrow">Get in Touch</p>
    <h1>Contact Us</h1>
    <p class="contact-hero-sub">Give us a call and we'll get it sorted.</p>
  </div>

  <div class="contact-cta">
    <p class="cta-label">Ready to schedule?</p>
    <a href={`tel:${MAIN_PHONE_NUMBER}`} class="cta-phone">{MAIN_PHONE_NUMBER}</a>
    <a href={`tel:${MAIN_PHONE_NUMBER}`} class="cta-button">
      <i class="ti ti-phone"></i> Call Now
    </a>
    <div class="cta-details">
      <span><i class="ti ti-map-pin"></i> North Fort Worth &amp; DFW</span>
    </div>
  </div>

  <div class="contact-photo" style={`background-image: url('${bgImg.src}')`}></div>
</Layout>

<style>
  .contact-hero {
    background: var(--color-secondary);
    color: #fff;
    text-align: center;
    padding: 5rem 2rem 4.5rem;

    .contact-eyebrow {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }

    h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.05;
      margin-bottom: 1rem;
    }

    .contact-hero-sub {
      font-size: 1.15rem;
      opacity: 0.75;
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }
  }

  .contact-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 5rem 2rem;
    background: var(--color-lighter-neutral);

    .cta-label {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
  }

  .cta-phone {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 800;
    color: var(--color-secondary);
    text-decoration: none;
    letter-spacing: -0.01em;
    line-height: 1;

    &:hover {
      color: var(--color-primary);
    }
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    background: var(--color-primary);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(152, 164, 90, 0.4);
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;

    &:hover {
      background: var(--color-primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(152, 164, 90, 0.5);
    }
  }

  .cta-details {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
    color: var(--color-secondary);
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0.75;

    span {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    i {
      color: var(--color-primary);
      font-size: 1rem;
    }
  }

  .detail-divider {
    width: 1px;
    height: 1rem;
    background: rgba(0, 0, 0, 0.2);

    @media (max-width: 500px) {
      display: none;
    }
  }

  .contact-photo {
    width: 100%;
    height: 420px;
    background-size: cover;
    background-position: center 30%;

    @media (max-width: 768px) {
      height: 260px;
    }
  }
</style>
